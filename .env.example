# ══════════════════════════════════════════════════════════════
# IF Nodes — Variables de entorno (desarrollo)
# Copiar a .env y completar. NUNCA commitear secretos reales.
# ══════════════════════════════════════════════════════════════

# ── Base de datos (coincide con docker/docker-compose.yml) ────
DATABASE_URL="postgresql://ifnodes:ifnodes_dev@localhost:5432/ifnodes?schema=public"

# ── Redis (colas y eventos — se usa desde Fase 3) ─────────────
REDIS_URL="redis://localhost:6379"

# ── API ───────────────────────────────────────────────────────
API_PORT=3001
WEB_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Secreto para firmar material de sesión. Generar: openssl rand -hex 32
SESSION_SECRET="reemplazar-con-64-caracteres-hex-aleatorios"

# Clave maestra AES-256-GCM para credenciales (Fase 7). Generar: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY="reemplazar-con-64-caracteres-hex-aleatorios"

# ── Autenticación ─────────────────────────────────────────────
# Emails del equipo autorizados (separados por coma). Todo lo demás se rechaza.
AUTHORIZED_EMAILS="vos@tuequipo.com,otro@tuequipo.com"

# Google OAuth (Google Cloud Console → Credentials → OAuth Client ID, tipo Web)
# Redirect URI autorizada: http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"

# Ingreso de desarrollo SIN Google (solo mientras no haya credenciales OAuth).
# Se ignora por completo si NODE_ENV=production. Ver SECURITY.md.
AUTH_DEV_LOGIN="true"

# ── Web ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL interna de la API para el rewrite /api/* del frontend
API_INTERNAL_URL="http://localhost:3001"
